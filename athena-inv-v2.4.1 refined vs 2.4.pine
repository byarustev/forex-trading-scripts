// Athena Inv V2.2 — Multi-POI tracking (4H + 1H).
// Tracks ALL POIs: 4H (main + candle-before-impulse OB), 1H ChoCH OB, continuation OB/FVG.
// Tracks mitigation: zones price has not yet revisited are highlighted (unmitigated POIs).
//
// 4H TREND: Confirmed only when BOTH ChoCH and BoS occur (ChoCH = break of previous swing; BoS = break of last swing). Signal direction follows trend: BUY only in bullish 4H trend, SELL only in bearish 4H trend (no counter-trend alerts).
//
// iFVG flow: HTF POI detected → track historical 1H FVGs (including those formed as price heads TO the POI) → when POI taps and price reverses, detect full 1H close through any stored gap → FVG becomes iFVG → signal retrace entry at mid of iFVG.
// Two iFVG entry types (different conditions):
// • 1H iFVG: After price revisits a 4H POI we store each new 1H FVG. When a full 1H candle closes through any stored gap (inversion), that FVG → iFVG. Entry = limit at mid of iFVG. Multi-TP.
// • 15M iFVG: After price hits a 1H POI (unmitigated + FVG) → 15M FVG inverts in trend direction → entry at 15M iFVG revisit. 1:3 R:R. (Separate logic.)
//
// Breaker Blocks: Last opposite candle before ChoCH/BoS. 4H Breaker = zone at that candle on 4H; 1H Breaker = zone at that candle on 1H. Same entry logic: 4H POIs (incl. 4H Breaker) → 1H iFVG or 15M ChoCH+BoS; 1H POIs (incl. 1H Breaker) → 5M ChoCH+BoS or 15M iFVG hold.
//
// Continuation trades: Within N bars (e.g. 2–3) after 4H structure change, also take 1H iFVG entries when price touches 1H POIs (continuation OB/FVG) in the direction of the new bias.
// 4H FVG: 4H Fair Value Gaps are added as 4H POIs (src=4.0); when price revisits a 4H FVG zone, 1H iFVG entry model is valid (same as other 4H POIs).

//@version=5
indicator("Athena Inv V2.2 — Multi-POI, FVG & Entry", shorttitle="Athena V2.2", overlay=true, max_boxes_count=500, max_lines_count=500, max_labels_count=500)

// ═══════════════════════════════════════════════════════════════
// INPUTS
// ═══════════════════════════════════════════════════════════════
grp_struct = "Structure (4H)"
tf_struct   = input.timeframe("240", "Structure timeframe", group=grp_struct, tooltip="Timeframe for swing points and BoS (e.g. 240 = 4H)")
swing_len   = input.int(5, "Swing length (left/right bars)", minval=2, maxval=20, group=grp_struct)
show_swings = input.bool(true, "Show swing highs/lows", group=grp_struct)
show_bos    = input.bool(true, "Show Break of Structure", group=grp_struct)
show_poi    = input.bool(true, "Show POI zones (fresh supply/demand)", group=grp_struct)
poi_atr_mult = input.float(0.5, "POI zone width (× ATR)", minval=0.1, step=0.1, group=grp_struct)

grp_fvg = "FVG (1H)"
tf_fvg   = input.timeframe("60", "FVG timeframe", group=grp_fvg, tooltip="Timeframe for Fair Value Gaps (e.g. 60 = 1H)")
show_fvg = input.bool(true, "Show FVG boxes", group=grp_fvg)
show_inv = input.bool(true, "Show FVG inversion & entry", group=grp_fvg)
fvg_use_body = input.bool(true, "FVG by body only (exclude wicks)", group=grp_fvg, tooltip="When on: FVG zone = gap between candle bodies (open/close). When off: use full range (high/low).")
max_hist_fvg = input.int(15, "Max historical 1H FVGs to track", minval=5, maxval=30, group=grp_fvg, tooltip="Store 1H FVGs as price heads to the POI (and after). These gaps get inversed when POI taps and price reverses; inversion = full candle close through any stored gap.")
min_fvg_atr = input.float(0.08, "Min FVG size (× 1H ATR)", minval=0.0, step=0.02, group=grp_fvg, tooltip="Only treat as FVG when gap height ≥ this × 1H ATR (avoids tiny/no visible gaps)")

grp_cont = "Continuation POIs (OB + FVG)"
use_continuation_poi = input.bool(true, "Use continuation POIs (OB & FVG left after move)", group=grp_cont, tooltip="After BoS, new zones (order block + FVG) become additional POIs when price retraces to fill them")
show_cont_poi       = input.bool(true, "Show continuation POI zones", group=grp_cont)
show_unmitigated    = input.bool(true, "Highlight unmitigated POIs (zones price has not yet revisited)", group=grp_cont)
show_breaker_blocks = input.bool(true, "Mark Breaker Blocks (4H/1H — last opposite candle before break)", group=grp_cont)
continuation_window_bars = input.int(3, "Continuation window (bars after structure change)", minval=1, maxval=15, group=grp_cont, tooltip="Within this many bars after 4H trend confirm, allow entries when price touches 1H continuation POIs (trades in direction of new bias)")
use_4h_fvg_poi     = input.bool(true, "Use 4H FVG as POI (1H iFVG entry)", group=grp_cont, tooltip="Add 4H Fair Value Gaps as 4H POIs; when price revisits them, 1H iFVG entry model applies")
max_pois            = input.int(20, "Max POIs to track per bias", minval=5, maxval=50, group=grp_cont, tooltip="v2.2: All POIs are kept until this limit; when price hits any we evaluate for entry")

grp_ob = "Entry: 4H POI + 1H ChoCH (limit at OB before rally)"
use_4h_poi_choch     = input.bool(true, "At 4H POI: limit at 1H OB (candle before rally)", group=grp_ob, tooltip="When price is at a 4H POI and 1H shows change in state of delivery (ChoCH), place limit at the order block before the rally.")
show_4h_poi_choch_limit = input.bool(true, "Show limit level & label", group=grp_ob)

grp_liq = "1H POI + Liquidity (below inducement)"
use_liquidity_poi   = input.bool(true, "Entry at unmitigated 1H POI below inducement (EQL) / above (EQH)", group=grp_liq)
show_liquidity_poi  = input.bool(true, "Show limit level & label", group=grp_liq)
eql_eqh_atr_tol     = input.float(0.3, "EQL/EQH tolerance (× 1H ATR)", minval=0.05, step=0.05, group=grp_liq, tooltip="Two swing lows/highs within this × ATR = Equal Lows/Highs (inducement)")
show_eql_eqh        = input.bool(false, "Show EQL / EQH (inducement) levels", group=grp_liq)

grp_risk = "Entry & Risk"
show_entry_sl_tp = input.bool(true, "Show entry, SL, TP levels", group=grp_risk)
use_premium_discount = input.bool(true, "Premium/Discount filter (sells in premium, buys in discount)", group=grp_risk, tooltip="Only take sells above 50% equilibrium, buys below 50%")
extend_sl_tp_bars  = input.int(12, "Entry/SL/TP line length (bars, right only)", minval=5, maxval=50, group=grp_risk, tooltip="Bars to the right of entry bar only; no left extension to reduce chart noise")
hide_entry_after_bars = input.int(18, "Hide Entry/SL/TP after (bars past entry)", minval=5, maxval=100, group=grp_risk, tooltip="Remove entry/SL/TP lines after this many bars so they don't extend to the left forever")
extend_limit_bars  = input.int(50, "Limit line length (bars) — POI+Liquidity", minval=20, maxval=150, group=grp_risk, tooltip="Longer so limit levels stay visible on higher timeframes")
hide_limit_after_bars = input.int(60, "Hide Liquidity lines after (bars)", minval=20, maxval=200, group=grp_risk, tooltip="Remove limit lines after this many bars to reduce left-side clutter")
// SL: a few pips off recent 1H internal level (swing high for sells, swing low for buys)
swing_len_1h   = input.int(3, "1H internal swing length (for SL)", minval=2, maxval=10, group=grp_risk)
sl_buffer_atr  = input.float(0.15, "SL buffer (× 1H ATR beyond internal level)", minval=0.05, step=0.05, group=grp_risk)
// TPs: 3–4 levels — TP1/2/3 at fixed R:R, TP4 at previous 4H swing level (max)
tp_rr_1        = input.float(2.0, "TP1 R:R", minval=1.0, step=0.5, group=grp_risk)
tp_rr_2        = input.float(3.0, "TP2 R:R", minval=1.0, step=0.5, group=grp_risk)
tp_rr_3        = input.float(4.0, "TP3 R:R", minval=1.0, step=0.5, group=grp_risk)
use_swing_tp4  = input.bool(true, "TP4 at previous 4H swing level (liquidity)", group=grp_risk)

// ═══════════════════════════════════════════════════════════════
// 4H STRUCTURE — Pivot highs/lows and BoS
// ═══════════════════════════════════════════════════════════════
[ph_4h, pl_4h] = request.security(syminfo.tickerid, tf_struct, [ta.pivothigh(high, swing_len, swing_len), ta.pivotlow(low, swing_len, swing_len)], lookahead=barmerge.lookahead_off)
close_4h = request.security(syminfo.tickerid, tf_struct, close, lookahead=barmerge.lookahead_off)

var float last_swing_high = na
var float last_swing_low  = na
var float prev_4h_swing_high = na  // previous 4H swing (for ChoCH: trend needs both ChoCH + BoS)
var float prev_4h_swing_low  = na
var int   bias            = 0   // 1 = bullish, -1 = bearish
var float poi_high        = na  // supply zone (bearish)
var float poi_low         = na  // demand zone (bullish)
var bool  poi_revisited   = false  // true only after price has traded into ANY tracked POI
var bool  entry_taken     = false  // one entry per setup; reset on new BoS
var bool  bos_bull_done   = false
var bool  bos_bear_done   = false
// v2.2: Track multiple POIs per bias (main + continuation OB/FVG); no overwrite
var array<float> supply_zone_hi = array.new_float(0)
var array<float> supply_zone_lo = array.new_float(0)
var array<float> demand_zone_hi = array.new_float(0)
var array<float> demand_zone_lo = array.new_float(0)
var array<float> supply_mitigated = array.new_float(0)  // 0 = unmitigated, 1 = mitigated
var array<float> demand_mitigated = array.new_float(0)
var array<float> supply_zone_src  = array.new_float(0)  // 4.0 = 4H POI, 1.0 = 1H POI (for Entry Model 2)
var array<float> demand_zone_src = array.new_float(0)
var array<float> supply_zone_is_breaker = array.new_float(0)  // 1.0 = Breaker Block (last opposite candle before break)
var array<float> demand_zone_is_breaker = array.new_float(0)
var bool choch_1h_bull_done = false
var bool choch_1h_bear_done = false
var bool revisited_1h_poi = false  // price has traded into at least one 1H-tagged POI (for Model 2)
var bool revisited_4h_poi = false
var int  bars_since_trend_confirm = 500  // bars since last 4H ChoCH+BoS; used for continuation-window entries
var float last_4h_fvg_bull_hi = na
var float last_4h_fvg_bull_lo = na
var float last_4h_fvg_bear_hi = na
var float last_4h_fvg_bear_lo = na
// Historical 1H FVGs (after HTF POI tap): track gaps so we detect full-candle close through any of them → iFVG
var array<float> hist_fvg_bear_tops = array.new_float(0)
var array<float> hist_fvg_bear_bots = array.new_float(0)
var array<float> hist_fvg_bull_tops = array.new_float(0)
var array<float> hist_fvg_bull_bots = array.new_float(0)

if not na(ph_4h)
    prev_4h_swing_high := last_swing_high
    last_swing_high := ph_4h
    bos_bull_done := false  // new high — allow next bullish BoS
if not na(pl_4h)
    prev_4h_swing_low := last_swing_low
    last_swing_low := pl_4h
    bos_bear_done := false  // new low — allow next bearish BoS

// 4H trend = ChoCH + BoS (both required). ChoCH = break of previous swing; BoS = break of last swing.
bool choch_4h_bull = not na(prev_4h_swing_high) and close_4h > prev_4h_swing_high
bool choch_4h_bear = not na(prev_4h_swing_low)  and close_4h < prev_4h_swing_low
bool has_swing_high = not na(last_swing_high)
bool has_swing_low  = not na(last_swing_low)
bool bos_bull       = has_swing_high and close_4h > last_swing_high and not bos_bull_done
bool bos_bear       = has_swing_low  and close_4h < last_swing_low  and not bos_bear_done
// Only confirm trend when BOTH ChoCH and BoS in same direction (or just BoS if no prev swing yet)
bool trend_confirmed_bull = bos_bull and (na(prev_4h_swing_high) or choch_4h_bull)
bool trend_confirmed_bear = bos_bear and (na(prev_4h_swing_low)  or choch_4h_bear)
// Mark BoS as "used" so we don't re-evaluate the same break every bar (bias only set when trend confirmed)
if bos_bull
    bos_bull_done := true
if bos_bear
    bos_bear_done := true

// Need atr_4h, zone bounds, previous 4H bar (candle before impulse = OB/Breaker), and its open/close for Breaker
float atr_4h = request.security(syminfo.tickerid, tf_struct, ta.atr(14), lookahead=barmerge.lookahead_off)
[prev_4h_high, prev_4h_low, prev_4h_open, prev_4h_close] = request.security(syminfo.tickerid, tf_struct, [high[1], low[1], open[1], close[1]], lookahead=barmerge.lookahead_off)
bool prev_4h_bearish = not na(prev_4h_open) and not na(prev_4h_close) and prev_4h_close < prev_4h_open  // last bearish candle before bull break = Bullish Breaker
bool prev_4h_bullish = not na(prev_4h_open) and not na(prev_4h_close) and prev_4h_close > prev_4h_open  // last bullish candle before bear break = Bearish Breaker
// 4H FVG — valid POIs for 1H iFVG entry when price revisits (same body/wick option as 1H)
[bull_fvg_4h_w, bear_fvg_4h_w, fvg_4h_bull_t_w, fvg_4h_bull_b_w, fvg_4h_bear_t_w, fvg_4h_bear_b_w, open_4h_3, close_4h_3, open_4h_1, close_4h_1] = request.security(syminfo.tickerid, tf_struct, [high[3] < low[1], low[3] > high[1], low[1], high[3], low[3], high[1], open[3], close[3], open[1], close[1]], lookahead=barmerge.lookahead_off)
float body_4h_hi_3 = math.max(open_4h_3, close_4h_3)
float body_4h_lo_3 = math.min(open_4h_3, close_4h_3)
float body_4h_hi_1 = math.max(open_4h_1, close_4h_1)
float body_4h_lo_1 = math.min(open_4h_1, close_4h_1)
bool bull_fvg_4h = fvg_use_body ? (body_4h_hi_3 < body_4h_lo_1) : bull_fvg_4h_w
bool bear_fvg_4h = fvg_use_body ? (body_4h_lo_3 > body_4h_hi_1) : bear_fvg_4h_w
float fvg_4h_bull_t = fvg_use_body ? body_4h_lo_1 : fvg_4h_bull_t_w
float fvg_4h_bull_b = fvg_use_body ? body_4h_hi_3 : fvg_4h_bull_b_w
float fvg_4h_bear_t = fvg_use_body ? body_4h_lo_3 : fvg_4h_bear_t_w
float fvg_4h_bear_b = fvg_use_body ? body_4h_hi_1 : fvg_4h_bear_b_w
float poi_high_lo = na
float poi_high_hi = na
float poi_low_lo  = na
float poi_low_hi  = na
if not na(poi_high)
    poi_high_lo := poi_high - poi_atr_mult * atr_4h
    poi_high_hi := poi_high + poi_atr_mult * atr_4h
if not na(poi_low)
    poi_low_lo := poi_low - poi_atr_mult * atr_4h
    poi_low_hi := poi_low + poi_atr_mult * atr_4h

if trend_confirmed_bull
    bias := 1
    poi_low := last_swing_low
    poi_revisited := false
    entry_taken := false
    bos_bear_done := false
    choch_1h_bull_done := false
    array.clear(demand_zone_hi)
    array.clear(demand_zone_lo)
    array.clear(demand_mitigated)
    array.clear(demand_zone_src)
    array.clear(demand_zone_is_breaker)
    revisited_1h_poi := false
    revisited_4h_poi := false
    float d_lo = last_swing_low - poi_atr_mult * atr_4h
    float d_hi = last_swing_low + poi_atr_mult * atr_4h
    array.push(demand_zone_hi, d_hi)
    array.push(demand_zone_lo, d_lo)
    array.push(demand_mitigated, 0.0)
    array.push(demand_zone_src, 4.0)
    array.push(demand_zone_is_breaker, 0.0)
    if not na(prev_4h_high) and not na(prev_4h_low)
        array.push(demand_zone_hi, prev_4h_high)
        array.push(demand_zone_lo, prev_4h_low)
        array.push(demand_mitigated, 0.0)
        array.push(demand_zone_src, 4.0)
        array.push(demand_zone_is_breaker, prev_4h_bearish ? 1.0 : 0.0)  // 4H Bullish Breaker = last bearish candle before break
if trend_confirmed_bear
    bias := -1
    poi_high := last_swing_high
    poi_revisited := false
    entry_taken := false
    bos_bull_done := false
    choch_1h_bear_done := false
    array.clear(supply_zone_hi)
    array.clear(supply_zone_lo)
    array.clear(supply_mitigated)
    array.clear(supply_zone_src)
    array.clear(supply_zone_is_breaker)
    revisited_1h_poi := false
    revisited_4h_poi := false
    float s_lo = last_swing_high - poi_atr_mult * atr_4h
    float s_hi = last_swing_high + poi_atr_mult * atr_4h
    array.push(supply_zone_hi, s_hi)
    array.push(supply_zone_lo, s_lo)
    array.push(supply_mitigated, 0.0)
    array.push(supply_zone_src, 4.0)
    array.push(supply_zone_is_breaker, 0.0)
    if not na(prev_4h_high) and not na(prev_4h_low)
        array.push(supply_zone_hi, prev_4h_high)
        array.push(supply_zone_lo, prev_4h_low)
        array.push(supply_mitigated, 0.0)
        array.push(supply_zone_src, 4.0)
        array.push(supply_zone_is_breaker, prev_4h_bullish ? 1.0 : 0.0)  // 4H Bearish Breaker = last bullish candle before break
if trend_confirmed_bull or trend_confirmed_bear
    bars_since_trend_confirm := 0
    last_4h_fvg_bull_hi := na
    last_4h_fvg_bull_lo := na
    last_4h_fvg_bear_hi := na
    last_4h_fvg_bear_lo := na
    array.clear(hist_fvg_bear_tops)
    array.clear(hist_fvg_bear_bots)
    array.clear(hist_fvg_bull_tops)
    array.clear(hist_fvg_bull_bots)
else
    bars_since_trend_confirm := math.min(bars_since_trend_confirm + 1, 500)

// 4H FVG as POI — push to demand/supply with src=4.0 so revisit triggers 1H iFVG entry (one push per distinct 4H FVG)
if use_4h_fvg_poi and bias == 1 and bull_fvg_4h and not na(fvg_4h_bull_t) and not na(fvg_4h_bull_b) and (na(last_4h_fvg_bull_hi) or last_4h_fvg_bull_hi != fvg_4h_bull_t or last_4h_fvg_bull_lo != fvg_4h_bull_b)
    last_4h_fvg_bull_hi := fvg_4h_bull_t
    last_4h_fvg_bull_lo := fvg_4h_bull_b
    while array.size(demand_zone_hi) >= max_pois
        array.shift(demand_zone_hi)
        array.shift(demand_zone_lo)
        array.shift(demand_mitigated)
        array.shift(demand_zone_src)
        array.shift(demand_zone_is_breaker)
    array.push(demand_zone_hi, fvg_4h_bull_t)
    array.push(demand_zone_lo, fvg_4h_bull_b)
    array.push(demand_mitigated, 0.0)
    array.push(demand_zone_src, 4.0)
    array.push(demand_zone_is_breaker, 0.0)
if use_4h_fvg_poi and bias == -1 and bear_fvg_4h and not na(fvg_4h_bear_t) and not na(fvg_4h_bear_b) and (na(last_4h_fvg_bear_hi) or last_4h_fvg_bear_hi != fvg_4h_bear_b or last_4h_fvg_bear_lo != fvg_4h_bear_t)
    last_4h_fvg_bear_hi := fvg_4h_bear_b
    last_4h_fvg_bear_lo := fvg_4h_bear_t
    while array.size(supply_zone_hi) >= max_pois
        array.shift(supply_zone_hi)
        array.shift(supply_zone_lo)
        array.shift(supply_mitigated)
        array.shift(supply_zone_src)
        array.shift(supply_zone_is_breaker)
    array.push(supply_zone_hi, fvg_4h_bear_b)
    array.push(supply_zone_lo, fvg_4h_bear_t)
    array.push(supply_mitigated, 0.0)
    array.push(supply_zone_src, 4.0)
    array.push(supply_zone_is_breaker, 0.0)

// Premium/Discount: 50% equilibrium of range (last 4H swing high ↔ swing low). Sells only in premium (above 50%), buys only in discount (below 50%).
float equilibrium = (not na(last_swing_high) and not na(last_swing_low)) ? (last_swing_high + last_swing_low) / 2.0 : na

// Revisit = price (1H candle) has traded into ANY tracked POI zone (v2.2: loop over arrays)
[h_1h, l_1h] = request.security(syminfo.tickerid, tf_fvg, [high, low], lookahead=barmerge.lookahead_off)
int ns = array.size(supply_zone_hi)
int nd = array.size(demand_zone_hi)
bool in_any_supply = false
bool in_any_demand = false
int nss = array.size(supply_zone_src)
int nds = array.size(demand_zone_src)
int nsup_m = array.size(supply_mitigated)
int ndem_m = array.size(demand_mitigated)
if ns > 0
    for i = 0 to ns - 1
        if h_1h >= array.get(supply_zone_lo, i) and l_1h <= array.get(supply_zone_hi, i)
            in_any_supply := true
            if nss > i and array.get(supply_zone_src, i) == 1.0
                revisited_1h_poi := true
            else if nss > i and array.get(supply_zone_src, i) == 4.0
                revisited_4h_poi := true
            if array.size(supply_mitigated) > i and array.get(supply_mitigated, i) == 0.0
                array.set(supply_mitigated, i, 1.0)
if nd > 0
    for i = 0 to nd - 1
        if l_1h <= array.get(demand_zone_hi, i) and h_1h >= array.get(demand_zone_lo, i)
            in_any_demand := true
            if nds > i and array.get(demand_zone_src, i) == 1.0
                revisited_1h_poi := true
            else if nds > i and array.get(demand_zone_src, i) == 4.0
                revisited_4h_poi := true
            if array.size(demand_mitigated) > i and array.get(demand_mitigated, i) == 0.0
                array.set(demand_mitigated, i, 1.0)
if (bias == -1 and in_any_supply) or (bias == 1 and in_any_demand)
    poi_revisited := true

// ═══════════════════════════════════════════════════════════════
// 1H FVG — Fair Value Gaps and inversion (evaluated on FVG TF)
// Wick-based: Bullish FVG high[3]<low[1], Bearish low[3]>high[1].
// Body-based: Bullish = body_high[3]<body_low[1], Bearish = body_low[3]>body_high[1]; zone = body boundaries only.
// ═══════════════════════════════════════════════════════════════
// Bar [3] = candle before the FVG impulse; its range = Order Block (OB) for continuation POI
[bull_fvg_ok, bear_fvg_ok, fvg_bull_t, fvg_bull_b, fvg_bear_t, fvg_bear_b, close_fvg, h3, l3, atr_fvg, open_3, close_3, open_1, close_1] = request.security(syminfo.tickerid, tf_fvg,
  [high[3] < low[1], low[3] > high[1], low[1], high[3], low[3], high[1], close, high[3], low[3], ta.atr(14), open[3], close[3], open[1], close[1]],
  lookahead=barmerge.lookahead_off)

// Body boundaries (open/close only; wicks excluded)
float body_hi_3 = math.max(open_3, close_3)
float body_lo_3 = math.min(open_3, close_3)
float body_hi_1 = math.max(open_1, close_1)
float body_lo_1 = math.min(open_1, close_1)
bool bull_fvg_body_ok = body_hi_3 < body_lo_1
bool bear_fvg_body_ok = body_lo_3 > body_hi_1
float fvg_bull_t_body = body_lo_1
float fvg_bull_b_body = body_hi_3
float fvg_bear_t_body = body_lo_3
float fvg_bear_b_body = body_hi_1

bool bull_fvg_ok_use = fvg_use_body ? bull_fvg_body_ok : bull_fvg_ok
bool bear_fvg_ok_use = fvg_use_body ? bear_fvg_body_ok : bear_fvg_ok
float fvg_bull_t_use = fvg_use_body ? fvg_bull_t_body : fvg_bull_t
float fvg_bull_b_use = fvg_use_body ? fvg_bull_b_body : fvg_bull_b
float fvg_bear_t_use = fvg_use_body ? fvg_bear_t_body : fvg_bear_t
float fvg_bear_b_use = fvg_use_body ? fvg_bear_b_body : fvg_bear_b

float atr_1h_fvg = atr_fvg
bool fvg_bull_big_enough = min_fvg_atr <= 0.0 or (not na(atr_1h_fvg) and atr_1h_fvg > 0 and (fvg_bull_t_use - fvg_bull_b_use) >= atr_1h_fvg * min_fvg_atr)
bool fvg_bear_big_enough = min_fvg_atr <= 0.0 or (not na(atr_1h_fvg) and atr_1h_fvg > 0 and (fvg_bear_t_use - fvg_bear_b_use) >= atr_1h_fvg * min_fvg_atr)
bool bullish_fvg = bull_fvg_ok_use and fvg_bull_big_enough
bool bearish_fvg = bear_fvg_ok_use and fvg_bear_big_enough
float fvg_bull_top = fvg_bull_t_use
float fvg_bull_bot = fvg_bull_b_use
float fvg_bear_top = fvg_bear_t_use
float fvg_bear_bot = fvg_bear_b_use

// v2.2: Push continuation POIs to arrays (do not overwrite; cap at max_pois); tag as 1H (not Breakers)
if use_continuation_poi and bearish_fvg and bias == -1 and not na(h3) and not na(l3)
    while array.size(supply_zone_hi) >= max_pois
        array.shift(supply_zone_hi)
        array.shift(supply_zone_lo)
        array.shift(supply_mitigated)
        array.shift(supply_zone_src)
        array.shift(supply_zone_is_breaker)
    array.push(supply_zone_hi, h3)
    array.push(supply_zone_lo, l3)
    array.push(supply_mitigated, 0.0)
    array.push(supply_zone_src, 1.0)
    array.push(supply_zone_is_breaker, 0.0)
    while array.size(supply_zone_hi) >= max_pois
        array.shift(supply_zone_hi)
        array.shift(supply_zone_lo)
        array.shift(supply_mitigated)
        array.shift(supply_zone_src)
        array.shift(supply_zone_is_breaker)
    array.push(supply_zone_hi, fvg_bear_top)
    array.push(supply_zone_lo, fvg_bear_bot)
    array.push(supply_mitigated, 0.0)
    array.push(supply_zone_src, 1.0)
    array.push(supply_zone_is_breaker, 0.0)
if use_continuation_poi and bullish_fvg and bias == 1 and not na(h3) and not na(l3)
    while array.size(demand_zone_hi) >= max_pois
        array.shift(demand_zone_hi)
        array.shift(demand_zone_lo)
        array.shift(demand_mitigated)
        array.shift(demand_zone_src)
        array.shift(demand_zone_is_breaker)
    array.push(demand_zone_hi, h3)
    array.push(demand_zone_lo, l3)
    array.push(demand_mitigated, 0.0)
    array.push(demand_zone_src, 1.0)
    array.push(demand_zone_is_breaker, 0.0)
    while array.size(demand_zone_hi) >= max_pois
        array.shift(demand_zone_hi)
        array.shift(demand_zone_lo)
        array.shift(demand_mitigated)
        array.shift(demand_zone_src)
        array.shift(demand_zone_is_breaker)
    array.push(demand_zone_hi, fvg_bull_top)
    array.push(demand_zone_lo, fvg_bull_bot)
    array.push(demand_mitigated, 0.0)
    array.push(demand_zone_src, 1.0)
    array.push(demand_zone_is_breaker, 0.0)

// ═══════════════════════════════════════════════════════════════
// 1H iFVG entry — HTF POI tap → track historical 1H FVGs → detect full candle close through any gap → iFVG → retrace entry at mid
// BUY = bearish FVG inverts (close above gap). SELL = bullish FVG inverts (close below gap). Entry = limit at mid of iFVG.
// ═══════════════════════════════════════════════════════════════
bool in_continuation_window = bars_since_trend_confirm <= continuation_window_bars
bool poi_ok_for_ifvg = revisited_4h_poi or (in_continuation_window and revisited_1h_poi)

// Detect inversion = full 1H candle close through any *stored* FVG (not only the current bar's FVG)
int inv_bull_idx = -1
int inv_bear_idx = -1
int nb_hist_bull = array.size(hist_fvg_bull_tops)
int nb_hist_bear = array.size(hist_fvg_bear_tops)
if nb_hist_bull > 0
    for i = 0 to nb_hist_bull - 1
        if inv_bull_idx < 0 and not na(close_fvg) and close_fvg < array.get(hist_fvg_bull_bots, i)
            inv_bull_idx := i
            break
if nb_hist_bear > 0
    for i = 0 to nb_hist_bear - 1
        if inv_bear_idx < 0 and not na(close_fvg) and close_fvg > array.get(hist_fvg_bear_tops, i)
            inv_bear_idx := i
            break
float inv_bull_fvg_top = inv_bull_idx >= 0 ? array.get(hist_fvg_bull_tops, inv_bull_idx) : na
float inv_bull_fvg_bot = inv_bull_idx >= 0 ? array.get(hist_fvg_bull_bots, inv_bull_idx) : na
float inv_bear_fvg_top = inv_bear_idx >= 0 ? array.get(hist_fvg_bear_tops, inv_bear_idx) : na
float inv_bear_fvg_bot = inv_bear_idx >= 0 ? array.get(hist_fvg_bear_bots, inv_bear_idx) : na
bool inv_bull_fvg_raw = inv_bull_idx >= 0
bool inv_bear_fvg_raw = inv_bear_idx >= 0
bool inv_bull_fvg = inv_bull_fvg_raw and poi_ok_for_ifvg and not entry_taken
bool inv_bear_fvg = inv_bear_fvg_raw and poi_ok_for_ifvg and not entry_taken

// 1H internal structure for SL + close/prev bar for 1H ChoCH (candle before impulse = OB/Breaker)
[ph_1h, pl_1h, atr_1h, close_1h, prev_1h_high, prev_1h_low, prev_1h_open, prev_1h_close] = request.security(syminfo.tickerid, tf_fvg,
  [ta.pivothigh(high, swing_len_1h, swing_len_1h), ta.pivotlow(low, swing_len_1h, swing_len_1h), ta.atr(14), close, high[1], low[1], open[1], close[1]],
  lookahead=barmerge.lookahead_off)
bool prev_1h_bearish = not na(prev_1h_open) and not na(prev_1h_close) and prev_1h_close < prev_1h_open  // last bearish before bull ChoCH = 1H Bullish Breaker
bool prev_1h_bullish = not na(prev_1h_open) and not na(prev_1h_close) and prev_1h_close > prev_1h_open  // last bullish before bear ChoCH = 1H Bearish Breaker
var float last_1h_swing_high = na
var float last_1h_swing_low  = na
var float prev_1h_swing_high = na
var float prev_1h_swing_low  = na
if not na(ph_1h)
    prev_1h_swing_high := last_1h_swing_high
    last_1h_swing_high := ph_1h
    choch_1h_bull_done := false
if not na(pl_1h)
    prev_1h_swing_low := last_1h_swing_low
    last_1h_swing_low := pl_1h
    choch_1h_bear_done := false
bool has_eql = not na(last_1h_swing_low) and not na(prev_1h_swing_low) and not na(atr_1h) and atr_1h > 0 and math.abs(last_1h_swing_low - prev_1h_swing_low) <= atr_1h * eql_eqh_atr_tol
bool has_eqh = not na(last_1h_swing_high) and not na(prev_1h_swing_high) and not na(atr_1h) and atr_1h > 0 and math.abs(last_1h_swing_high - prev_1h_swing_high) <= atr_1h * eql_eqh_atr_tol
float eql_level = has_eql ? (last_1h_swing_low + prev_1h_swing_low) / 2.0 : na
float eqh_level = has_eqh ? (last_1h_swing_high + prev_1h_swing_high) / 2.0 : na
bool has_1h_swing_high = not na(last_1h_swing_high)
bool has_1h_swing_low  = not na(last_1h_swing_low)
bool choch_1h_bull = has_1h_swing_high and not na(close_1h) and close_1h > last_1h_swing_high and not choch_1h_bull_done
bool choch_1h_bear = has_1h_swing_low  and not na(close_1h) and close_1h < last_1h_swing_low  and not choch_1h_bear_done
if choch_1h_bull and not na(prev_1h_high) and not na(prev_1h_low)
    choch_1h_bull_done := true
    while array.size(demand_zone_hi) >= max_pois
        array.shift(demand_zone_hi)
        array.shift(demand_zone_lo)
        array.shift(demand_mitigated)
        array.shift(demand_zone_src)
        array.shift(demand_zone_is_breaker)
    array.push(demand_zone_hi, prev_1h_high)
    array.push(demand_zone_lo, prev_1h_low)
    array.push(demand_mitigated, 0.0)
    array.push(demand_zone_src, 1.0)
    array.push(demand_zone_is_breaker, prev_1h_bearish ? 1.0 : 0.0)  // 1H Bullish Breaker = last bearish candle before break
if choch_1h_bear and not na(prev_1h_high) and not na(prev_1h_low)
    choch_1h_bear_done := true
    while array.size(supply_zone_hi) >= max_pois
        array.shift(supply_zone_hi)
        array.shift(supply_zone_lo)
        array.shift(supply_mitigated)
        array.shift(supply_zone_src)
        array.shift(supply_zone_is_breaker)
    array.push(supply_zone_hi, prev_1h_high)
    array.push(supply_zone_lo, prev_1h_low)
    array.push(supply_mitigated, 0.0)
    array.push(supply_zone_src, 1.0)
    array.push(supply_zone_is_breaker, prev_1h_bullish ? 1.0 : 0.0)  // 1H Bearish Breaker = last bullish candle before break

// ─── Entry: 4H POI + 1H Change in state of delivery → limit at OB before the rally ─────
var float ob_limit_level = na
var int   ob_limit_bar   = 0
var bool  ob_limit_is_buy = false
var line  ob_limit_line   = na
var label ob_limit_lbl    = na
bool ob_limit_trigger_buy  = false
bool ob_limit_trigger_sell = false
if use_4h_poi_choch
    if bias == 1 and revisited_4h_poi and choch_1h_bull and not na(prev_1h_low)
        ob_limit_level := prev_1h_low
        ob_limit_bar   := bar_index
        ob_limit_is_buy := true
        ob_limit_trigger_buy := true
    else if bias == -1 and revisited_4h_poi and choch_1h_bear and not na(prev_1h_high)
        ob_limit_level := prev_1h_high
        ob_limit_bar   := bar_index
        ob_limit_is_buy := false
        ob_limit_trigger_sell := true
if bos_bull or bos_bear
    ob_limit_level := na
    ob_limit_bar   := 0
    if not na(ob_limit_line)
        line.delete(ob_limit_line)
        ob_limit_line := na
    if not na(ob_limit_lbl)
        label.delete(ob_limit_lbl)
        ob_limit_lbl := na

// ─── 1H POI + Liquidity (unmitigated POI below inducement EQL / above EQH) ─────
var float liq_poi_level = na
var bool  liq_poi_is_buy = false
var int   liq_poi_bar    = 0
var line  liq_poi_line   = na
var label liq_poi_lbl    = na

bool liq_poi_buy_trigger  = false
bool liq_poi_sell_trigger = false
if use_liquidity_poi
    liq_poi_level := na
    if bias == 1 and not na(eql_level) and nd > 0
        for i = 0 to nd - 1
            if nds > i and array.get(demand_zone_src, i) == 1.0 and ndem_m > i and array.get(demand_mitigated, i) == 0.0
                float d_hi = array.get(demand_zone_hi, i)
                float d_lo = array.get(demand_zone_lo, i)
                if d_hi < eql_level
                    liq_poi_level := (d_hi + d_lo) / 2.0
                    liq_poi_is_buy := true
                    liq_poi_bar    := bar_index
                    liq_poi_buy_trigger := true
                    break
    if bias == -1 and not na(eqh_level) and ns > 0
        for i = 0 to ns - 1
            if nss > i and array.get(supply_zone_src, i) == 1.0 and nsup_m > i and array.get(supply_mitigated, i) == 0.0
                float s_hi = array.get(supply_zone_hi, i)
                float s_lo = array.get(supply_zone_lo, i)
                if s_lo > eqh_level
                    liq_poi_level := (s_hi + s_lo) / 2.0
                    liq_poi_is_buy := false
                    liq_poi_bar    := bar_index
                    liq_poi_sell_trigger := true
                    break
if trend_confirmed_bull or trend_confirmed_bear
    liq_poi_level := na
    liq_poi_bar   := 0
    if not na(liq_poi_line)
        line.delete(liq_poi_line)
        liq_poi_line := na
    if not na(liq_poi_lbl)
        label.delete(liq_poi_lbl)
        liq_poi_lbl := na

// Track last valid FVG for entry/SL/TP (after inversion we use that FVG's mid as entry)
var float entry_level = na
var float sl_level    = na
var float tp1_level   = na
var float tp2_level   = na
var float tp3_level   = na
var float tp4_level   = na
var int   entry_bar   = 0   // bar index when entry was taken (for drawing SL/TP lines)
var line  entry_line  = na
var line  sl_line     = na
var line  tp1_line    = na
var line  tp2_line    = na
var line  tp3_line    = na
var line  tp4_line    = na
var label entry_lbl   = na
var label sl_lbl     = na
var label tp1_lbl    = na
var label tp2_lbl    = na
var label tp3_lbl    = na
var label tp4_lbl    = na
var float last_fvg_bull_top = na
var float last_fvg_bull_bot = na
var float last_fvg_bear_top = na
var float last_fvg_bear_bot = na
var float ifvg_zone_hi = na  // FVG zone that just inverted (so we can draw it)
var float ifvg_zone_lo = na
var box   ifvg_zone_box = na
var label ifvg_zone_lbl = na

// Store historical 1H FVGs as soon as we have bias (including FVGs formed as price heads TO the POI; these are the ones that get inversed when POI taps and price reverses)
if bearish_fvg and bias == 1
    last_fvg_bear_top := fvg_bear_top
    last_fvg_bear_bot := fvg_bear_bot
    int n_bear = array.size(hist_fvg_bear_tops)
    bool dup = false
    if n_bear > 0
        dup := array.get(hist_fvg_bear_tops, n_bear - 1) == fvg_bear_top and array.get(hist_fvg_bear_bots, n_bear - 1) == fvg_bear_bot
    if not dup
        while array.size(hist_fvg_bear_tops) >= max_hist_fvg
            array.shift(hist_fvg_bear_tops)
            array.shift(hist_fvg_bear_bots)
        array.push(hist_fvg_bear_tops, fvg_bear_top)
        array.push(hist_fvg_bear_bots, fvg_bear_bot)
if bullish_fvg and bias == -1
    last_fvg_bull_top := fvg_bull_top
    last_fvg_bull_bot := fvg_bull_bot
    int n_bull = array.size(hist_fvg_bull_tops)
    bool dup_b = false
    if n_bull > 0
        dup_b := array.get(hist_fvg_bull_tops, n_bull - 1) == fvg_bull_top and array.get(hist_fvg_bull_bots, n_bull - 1) == fvg_bull_bot
    if not dup_b
        while array.size(hist_fvg_bull_tops) >= max_hist_fvg
            array.shift(hist_fvg_bull_tops)
            array.shift(hist_fvg_bull_bots)
        array.push(hist_fvg_bull_tops, fvg_bull_top)
        array.push(hist_fvg_bull_bots, fvg_bull_bot)

// ─────────────────────────────────────────────────────────────────────────────
// BOT: Entry as pending order (for use when building the trading bot)
// ─────────────────────────────────────────────────────────────────────────────
// • Entry should be placed as a PENDING order a few pips from the middle of the iFVG
//   (not market order at signal time).
// • BUYS: Place the pending buy in the UPPER part of the iFVG (the smaller half).
//   iFVG for buys = inverted bearish FVG: top = last_fvg_bear_top, bottom = last_fvg_bear_bot,
//   middle = (last_fvg_bear_top + last_fvg_bear_bot) / 2. Upper part = from middle to top.
// • SELLS: Place the pending sell in the LOWER part of the iFVG (the smaller half).
//   iFVG for sells = inverted bullish FVG: top = last_fvg_bull_top, bottom = last_fvg_bull_bot,
//   middle = (last_fvg_bull_top + last_fvg_bull_bot) / 2. Lower part = from middle to bottom.
// ─────────────────────────────────────────────────────────────────────────────

// Sell setup: 4H bearish trend. Entry = retrace to middle of the iFVG (the FVG that just inverted).
float entry_sell = not na(inv_bull_fvg_top) and not na(inv_bull_fvg_bot) ? (inv_bull_fvg_top + inv_bull_fvg_bot) / 2.0 : na
bool sell_ok = bias == -1 and inv_bull_fvg and not na(entry_sell) and (not use_premium_discount or na(equilibrium) or entry_sell >= equilibrium)
if sell_ok
    entry_taken := true
    entry_bar   := bar_index
    entry_level := entry_sell
    ifvg_zone_hi := inv_bull_fvg_top
    ifvg_zone_lo := inv_bull_fvg_bot
    if inv_bull_idx >= 0 and array.size(hist_fvg_bull_tops) > inv_bull_idx
        array.remove(hist_fvg_bull_tops, inv_bull_idx)
        array.remove(hist_fvg_bull_bots, inv_bull_idx)
    float sl_buf = not na(atr_1h) ? atr_1h * sl_buffer_atr : entry_level * 0.005
    sl_level    := not na(last_1h_swing_high) ? last_1h_swing_high + sl_buf : (not na(poi_high) ? poi_high + poi_atr_mult * atr_4h : na)
    float risk  = sl_level - entry_level
    if not na(sl_level) and risk > 0
        tp1_level := entry_level - tp_rr_1 * risk
        tp2_level := entry_level - tp_rr_2 * risk
        tp3_level := entry_level - tp_rr_3 * risk
        tp4_level := use_swing_tp4 and not na(last_swing_low) and last_swing_low < entry_level ? last_swing_low : entry_level - tp_rr_3 * risk
    else
        tp1_level := na
        tp2_level := na
        tp3_level := na
        tp4_level := na

// Buy setup: 4H bullish trend. Entry = retrace to middle of the iFVG (the FVG that just inverted).
float entry_buy = not na(inv_bear_fvg_top) and not na(inv_bear_fvg_bot) ? (inv_bear_fvg_top + inv_bear_fvg_bot) / 2.0 : na
bool buy_ok = bias == 1 and inv_bear_fvg and not na(entry_buy) and (not use_premium_discount or na(equilibrium) or entry_buy <= equilibrium)
if buy_ok and not sell_ok
    entry_taken := true
    entry_bar   := bar_index
    entry_level := entry_buy
    ifvg_zone_hi := inv_bear_fvg_top
    ifvg_zone_lo := inv_bear_fvg_bot
    if inv_bear_idx >= 0 and array.size(hist_fvg_bear_tops) > inv_bear_idx
        array.remove(hist_fvg_bear_tops, inv_bear_idx)
        array.remove(hist_fvg_bear_bots, inv_bear_idx)
    float sl_buf = not na(atr_1h) ? atr_1h * sl_buffer_atr : entry_level * 0.005
    sl_level    := not na(last_1h_swing_low) ? last_1h_swing_low - sl_buf : (not na(poi_low) ? poi_low - poi_atr_mult * atr_4h : na)
    float risk  = entry_level - sl_level
    if not na(sl_level) and risk > 0
        tp1_level := entry_level + tp_rr_1 * risk
        tp2_level := entry_level + tp_rr_2 * risk
        tp3_level := entry_level + tp_rr_3 * risk
        tp4_level := use_swing_tp4 and not na(last_swing_high) and last_swing_high > entry_level ? last_swing_high : entry_level + tp_rr_3 * risk
    else
        tp1_level := na
        tp2_level := na
        tp3_level := na
        tp4_level := na

// Reset entry/SL/TP, stored FVG, and continuation POIs when bias flips (new BoS)
if bos_bull or bos_bear
    if not na(entry_line)
        line.delete(entry_line)
    if not na(sl_line)
        line.delete(sl_line)
    if not na(tp1_line)
        line.delete(tp1_line)
    if not na(tp2_line)
        line.delete(tp2_line)
    if not na(tp3_line)
        line.delete(tp3_line)
    if not na(tp4_line)
        line.delete(tp4_line)
    if not na(entry_lbl)
        label.delete(entry_lbl)
    if not na(sl_lbl)
        label.delete(sl_lbl)
    if not na(tp1_lbl)
        label.delete(tp1_lbl)
    if not na(tp2_lbl)
        label.delete(tp2_lbl)
    if not na(tp3_lbl)
        label.delete(tp3_lbl)
    if not na(tp4_lbl)
        label.delete(tp4_lbl)
    entry_line := na
    sl_line    := na
    tp1_line   := na
    tp2_line   := na
    tp3_line   := na
    tp4_line   := na
    entry_lbl  := na
    sl_lbl     := na
    tp1_lbl    := na
    tp2_lbl    := na
    tp3_lbl    := na
    tp4_lbl    := na
    entry_level := na
    sl_level    := na
    tp1_level   := na
    tp2_level   := na
    tp3_level   := na
    tp4_level   := na
    entry_taken := false
    entry_bar   := 0
    last_fvg_bull_top := na
    last_fvg_bull_bot := na
    last_fvg_bear_top := na
    last_fvg_bear_bot := na
    ifvg_zone_hi := na
    ifvg_zone_lo := na
    if not na(ifvg_zone_box)
        box.delete(ifvg_zone_box)
        ifvg_zone_box := na
    if not na(ifvg_zone_lbl)
        label.delete(ifvg_zone_lbl)
        ifvg_zone_lbl := na

// ═══════════════════════════════════════════════════════════════
// PLOTS — Swing points
// ═══════════════════════════════════════════════════════════════
plot(show_swings and not na(ph_4h) ? ph_4h : na, "4H Swing High", color.new(color.red, 0), 2, plot.style_circles)
plot(show_swings and not na(pl_4h) ? pl_4h : na, "4H Swing Low",  color.new(color.green, 0), 2, plot.style_circles)

// BoS labels
if show_bos and bos_bull
    label.new(bar_index, low, "BoS Bull", style=label.style_label_up, color=color.green, textcolor=color.white, size=size.small)
if show_bos and bos_bear
    label.new(bar_index, high, "BoS Bear", style=label.style_label_down, color=color.red, textcolor=color.white, size=size.small)

// v2.2: POI zones from arrays — draw up to 5 most recent supply/demand zones; unmitigated = purple/fuchsia; Breaker = distinct style
var box sup1 = na, var box sup2 = na, var box sup3 = na, var box sup4 = na, var box sup5 = na
var box dem1 = na, var box dem2 = na, var box dem3 = na, var box dem4 = na, var box dem5 = na
var label unmit_sup_label = na
var label unmit_dem_label = na
var label breaker_sup_label = na
var label breaker_dem_label = na
int nsup = array.size(supply_zone_hi)
int ndem = array.size(demand_zone_hi)
int nsup_br = array.size(supply_zone_is_breaker)
int ndem_br = array.size(demand_zone_is_breaker)
if show_poi and show_cont_poi
    if nsup > 0
        float sh1 = array.get(supply_zone_hi, nsup - 1), sl1 = array.get(supply_zone_lo, nsup - 1)
        bool u1 = show_unmitigated and nsup_m > nsup - 1 and array.get(supply_mitigated, nsup - 1) == 0.0
        bool br1 = show_breaker_blocks and nsup_br > nsup - 1 and array.get(supply_zone_is_breaker, nsup - 1) == 1.0
        float src1 = nss > nsup - 1 ? array.get(supply_zone_src, nsup - 1) : 0.0
        color c1_b = br1 ? color.blue : (u1 ? color.purple : color.red)
        color c1_f = br1 ? color.new(color.blue, 75) : (u1 ? color.new(color.purple, 70) : color.new(color.red, 85))
        if na(sup1)
            sup1 := box.new(bar_index - 10, sh1, bar_index + 5, sl1, border_color=c1_b, bgcolor=c1_f)
        else
            box.set_lefttop(sup1, bar_index - 2, sh1)
            box.set_rightbottom(sup1, bar_index + 5, sl1)
            box.set_border_color(sup1, c1_b)
            box.set_bgcolor(sup1, c1_f)
        if br1
            string br_txt = src1 == 4.0 ? "4H Breaker" : "1H Breaker"
            float mid1 = (sh1 + sl1) / 2.0
            if na(breaker_sup_label)
                breaker_sup_label := label.new(bar_index + 6, mid1, br_txt, style=label.style_label_left, color=color.blue, textcolor=color.white, size=size.tiny)
            else
                label.set_xy(breaker_sup_label, bar_index + 6, mid1)
                label.set_text(breaker_sup_label, br_txt)
        else if not na(breaker_sup_label)
            label.delete(breaker_sup_label)
            breaker_sup_label := na
    else
        if not na(sup1)
            box.delete(sup1)
            sup1 := na
        if not na(breaker_sup_label)
            label.delete(breaker_sup_label)
            breaker_sup_label := na
    if nsup > 1
        float sh2 = array.get(supply_zone_hi, nsup - 2), sl2 = array.get(supply_zone_lo, nsup - 2)
        bool u2 = show_unmitigated and nsup_m > nsup - 2 and array.get(supply_mitigated, nsup - 2) == 0.0
        bool br2 = show_breaker_blocks and nsup_br > nsup - 2 and array.get(supply_zone_is_breaker, nsup - 2) == 1.0
        color c2_b = br2 ? color.blue : (u2 ? color.purple : color.maroon)
        color c2_f = br2 ? color.new(color.blue, 78) : (u2 ? color.new(color.purple, 72) : color.new(color.maroon, 88))
        if na(sup2)
            sup2 := box.new(bar_index - 10, sh2, bar_index + 5, sl2, border_color=c2_b, bgcolor=c2_f)
        else
            box.set_lefttop(sup2, bar_index - 2, sh2)
            box.set_rightbottom(sup2, bar_index + 5, sl2)
            box.set_border_color(sup2, c2_b)
            box.set_bgcolor(sup2, c2_f)
    else
        if not na(sup2)
            box.delete(sup2)
            sup2 := na
    if nsup > 2
        float sh3 = array.get(supply_zone_hi, nsup - 3), sl3 = array.get(supply_zone_lo, nsup - 3)
        bool u3 = show_unmitigated and nsup_m > nsup - 3 and array.get(supply_mitigated, nsup - 3) == 0.0
        bool br3 = show_breaker_blocks and nsup_br > nsup - 3 and array.get(supply_zone_is_breaker, nsup - 3) == 1.0
        color c3_b = br3 ? color.blue : (u3 ? color.purple : color.orange)
        color c3_f = br3 ? color.new(color.blue, 80) : (u3 ? color.new(color.purple, 75) : color.new(color.orange, 90))
        if na(sup3)
            sup3 := box.new(bar_index - 10, sh3, bar_index + 5, sl3, border_color=c3_b, bgcolor=c3_f)
        else
            box.set_lefttop(sup3, bar_index - 2, sh3)
            box.set_rightbottom(sup3, bar_index + 5, sl3)
            box.set_border_color(sup3, c3_b)
            box.set_bgcolor(sup3, c3_f)
    else
        if not na(sup3)
            box.delete(sup3)
            sup3 := na
    if nsup <= 3
        if not na(sup4)
            box.delete(sup4)
            sup4 := na
        if not na(sup5)
            box.delete(sup5)
            sup5 := na
    if show_unmitigated and nsup > 0 and nsup_m >= nsup
        int ui = -1
        for j = nsup - 1 to 0
            if array.get(supply_mitigated, j) == 0.0
                ui := j
                break
        if ui >= 0
            float umid = (array.get(supply_zone_hi, ui) + array.get(supply_zone_lo, ui)) / 2.0
            if na(unmit_sup_label)
                unmit_sup_label := label.new(bar_index + 8, umid, "unmitigated\nPOI", style=label.style_label_left, color=color.purple, textcolor=color.white, size=size.tiny)
            else
                label.set_xy(unmit_sup_label, bar_index + 8, umid)
        else if not na(unmit_sup_label)
            label.delete(unmit_sup_label)
            unmit_sup_label := na
    else if not na(unmit_sup_label)
        label.delete(unmit_sup_label)
        unmit_sup_label := na
    if ndem > 0
        float dh1 = array.get(demand_zone_hi, ndem - 1), dl1 = array.get(demand_zone_lo, ndem - 1)
        bool u1 = show_unmitigated and ndem_m > ndem - 1 and array.get(demand_mitigated, ndem - 1) == 0.0
        bool br1 = show_breaker_blocks and ndem_br > ndem - 1 and array.get(demand_zone_is_breaker, ndem - 1) == 1.0
        float src1_d = nds > ndem - 1 ? array.get(demand_zone_src, ndem - 1) : 0.0
        color c1_b = br1 ? color.teal : (u1 ? color.fuchsia : color.green)
        color c1_f = br1 ? color.new(color.teal, 75) : (u1 ? color.new(color.fuchsia, 70) : color.new(color.green, 85))
        if na(dem1)
            dem1 := box.new(bar_index - 10, dh1, bar_index + 5, dl1, border_color=c1_b, bgcolor=c1_f)
        else
            box.set_lefttop(dem1, bar_index - 2, dh1)
            box.set_rightbottom(dem1, bar_index + 5, dl1)
            box.set_border_color(dem1, c1_b)
            box.set_bgcolor(dem1, c1_f)
        if br1
            string br_txt_d = src1_d == 4.0 ? "4H Breaker" : "1H Breaker"
            float mid1_d = (dh1 + dl1) / 2.0
            if na(breaker_dem_label)
                breaker_dem_label := label.new(bar_index + 6, mid1_d, br_txt_d, style=label.style_label_left, color=color.teal, textcolor=color.white, size=size.tiny)
            else
                label.set_xy(breaker_dem_label, bar_index + 6, mid1_d)
                label.set_text(breaker_dem_label, br_txt_d)
        else if not na(breaker_dem_label)
            label.delete(breaker_dem_label)
            breaker_dem_label := na
    else
        if not na(dem1)
            box.delete(dem1)
            dem1 := na
        if not na(breaker_dem_label)
            label.delete(breaker_dem_label)
            breaker_dem_label := na
    if ndem > 1
        float dh2 = array.get(demand_zone_hi, ndem - 2), dl2 = array.get(demand_zone_lo, ndem - 2)
        bool u2 = show_unmitigated and ndem_m > ndem - 2 and array.get(demand_mitigated, ndem - 2) == 0.0
        bool br2_d = show_breaker_blocks and ndem_br > ndem - 2 and array.get(demand_zone_is_breaker, ndem - 2) == 1.0
        color c2_b = br2_d ? color.teal : (u2 ? color.fuchsia : color.teal)
        color c2_f = br2_d ? color.new(color.teal, 78) : (u2 ? color.new(color.fuchsia, 72) : color.new(color.teal, 88))
        if na(dem2)
            dem2 := box.new(bar_index - 2, dh2, bar_index + 5, dl2, border_color=c2_b, bgcolor=c2_f)
        else
            box.set_lefttop(dem2, bar_index - 10, dh2)
            box.set_rightbottom(dem2, bar_index + 5, dl2)
            box.set_border_color(dem2, c2_b)
            box.set_bgcolor(dem2, c2_f)
    else
        if not na(dem2)
            box.delete(dem2)
            dem2 := na
    if ndem > 2
        float dh3 = array.get(demand_zone_hi, ndem - 3), dl3 = array.get(demand_zone_lo, ndem - 3)
        bool u3 = show_unmitigated and ndem_m > ndem - 3 and array.get(demand_mitigated, ndem - 3) == 0.0
        bool br3_d = show_breaker_blocks and ndem_br > ndem - 3 and array.get(demand_zone_is_breaker, ndem - 3) == 1.0
        color c3_b = br3_d ? color.teal : (u3 ? color.fuchsia : color.olive)
        color c3_f = br3_d ? color.new(color.teal, 80) : (u3 ? color.new(color.fuchsia, 75) : color.new(color.olive, 90))
        if na(dem3)
            dem3 := box.new(bar_index - 2, dh3, bar_index + 5, dl3, border_color=c3_b, bgcolor=c3_f)
        else
            box.set_lefttop(dem3, bar_index - 2, dh3)
            box.set_rightbottom(dem3, bar_index + 5, dl3)
            box.set_border_color(dem3, c3_b)
            box.set_bgcolor(dem3, c3_f)
    else
        if not na(dem3)
            box.delete(dem3)
            dem3 := na
    if ndem <= 3
        if not na(dem4)
            box.delete(dem4)
            dem4 := na
        if not na(dem5)
            box.delete(dem5)
            dem5 := na
    if show_unmitigated and ndem > 0 and ndem_m >= ndem
        int ui = -1
        for j = ndem - 1 to 0
            if array.get(demand_mitigated, j) == 0.0
                ui := j
                break
        if ui >= 0
            float umid = (array.get(demand_zone_hi, ui) + array.get(demand_zone_lo, ui)) / 2.0
            if na(unmit_dem_label)
                unmit_dem_label := label.new(bar_index + 8, umid, "unmitigated\nPOI", style=label.style_label_left, color=color.fuchsia, textcolor=color.white, size=size.tiny)
            else
                label.set_xy(unmit_dem_label, bar_index + 8, umid)
        else if not na(unmit_dem_label)
            label.delete(unmit_dem_label)
            unmit_dem_label := na
    else if not na(unmit_dem_label)
        label.delete(unmit_dem_label)
        unmit_dem_label := na

// FVG boxes (1H) — draw when a NEW FVG forms (may be replaced by next FVG; the iFVG zone above shows the one that triggered the entry)
var box fvg_bull_box = na
var box fvg_bear_box = na
if show_fvg and bullish_fvg
    if not na(fvg_bull_box)
        box.delete(fvg_bull_box)
    fvg_bull_box := box.new(bar_index - 1, fvg_bull_top, bar_index + 2, fvg_bull_bot, border_color=color.teal, bgcolor=color.new(color.teal, 80))
if show_fvg and bearish_fvg
    if not na(fvg_bear_box)
        box.delete(fvg_bear_box)
    fvg_bear_box := box.new(bar_index - 1, fvg_bear_top, bar_index + 2, fvg_bear_bot, border_color=color.orange, bgcolor=color.new(color.orange, 80))

// 4H POI + 1H ChoCH: limit at OB before rally — draw once as fixed line.new() segment
int ob_left   = ob_limit_bar
int ob_right  = ob_limit_bar + math.max(extend_limit_bars, 20)
bool ob_in_window = ob_limit_bar > 0 and bar_index <= ob_limit_bar + hide_limit_after_bars
if ob_limit_bar > 0 and not ob_in_window
    if not na(ob_limit_line)
        line.delete(ob_limit_line)
        ob_limit_line := na
    if not na(ob_limit_lbl)
        label.delete(ob_limit_lbl)
        ob_limit_lbl := na
if use_4h_poi_choch and show_4h_poi_choch_limit and ob_limit_bar > 0 and not na(ob_limit_level) and ob_in_window
    if na(ob_limit_line)
        ob_limit_line := line.new(ob_left, ob_limit_level, ob_right, ob_limit_level, color=color.orange, width=2)
        ob_limit_lbl  := label.new(ob_right, ob_limit_level, ob_limit_is_buy ? " 4H POI + 1H ChoCH Limit Buy (OB) " : " 4H POI + 1H ChoCH Limit Sell (OB) ", style=label.style_label_left, color=color.orange, textcolor=color.black, size=size.small)

// 1H POI + Liquidity: limit — hide after N bars so line does not extend left forever
int liq_left  = liq_poi_bar
int liq_right = liq_poi_bar + math.max(extend_limit_bars, 20)
bool liq_in_window = liq_poi_bar > 0 and bar_index <= liq_poi_bar + hide_limit_after_bars
if liq_poi_bar > 0 and not liq_in_window
    if not na(liq_poi_line)
        line.delete(liq_poi_line)
        liq_poi_line := na
    if not na(liq_poi_lbl)
        label.delete(liq_poi_lbl)
        liq_poi_lbl := na
// 1H POI + Liquidity: draw once as fixed line.new() segment, no updating
if use_liquidity_poi and show_liquidity_poi and liq_poi_bar > 0 and not na(liq_poi_level) and liq_in_window
    if na(liq_poi_line)
        liq_poi_line := line.new(liq_left, liq_poi_level, liq_right, liq_poi_level, color=color.aqua, width=2)
        liq_poi_lbl  := label.new(liq_right, liq_poi_level, liq_poi_is_buy ? " 1H POI + Liquidity (Buy) " : " 1H POI + Liquidity (Sell) ", style=label.style_label_left, color=color.aqua, textcolor=color.black, size=size.small)

// Entry / SL / TP: short horizontal segments from entry bar (fixed length so they don’t run into other entries)
int end_bar = entry_bar + math.max(extend_sl_tp_bars, 1)
bool entry_in_window = entry_bar > 0 and bar_index <= entry_bar + hide_entry_after_bars

// iFVG zone box — mark the inverted FVG to trade from; draw once, fixed width (same as entry segment)
int ifvg_right = entry_bar + math.max(extend_sl_tp_bars, 1)
bool ifvg_visible = show_entry_sl_tp and entry_bar > 0 and not na(ifvg_zone_hi) and not na(ifvg_zone_lo) and entry_in_window and entry_bar < ifvg_right
if show_entry_sl_tp and entry_bar > 0 and not entry_in_window
    if not na(ifvg_zone_box)
        box.delete(ifvg_zone_box)
        ifvg_zone_box := na
    if not na(ifvg_zone_lbl)
        label.delete(ifvg_zone_lbl)
        ifvg_zone_lbl := na
if ifvg_visible and na(ifvg_zone_box)
    ifvg_zone_box := box.new(entry_bar, ifvg_zone_hi, ifvg_right, ifvg_zone_lo, border_color=color.purple, bgcolor=color.new(color.purple, 70))
    float ifvg_mid = (ifvg_zone_hi + ifvg_zone_lo) / 2.0
    ifvg_zone_lbl := label.new(ifvg_right, ifvg_mid, " iFVG\n(trade from zone) ", style=label.style_label_left, color=color.purple, textcolor=color.white, size=size.small)

if entry_bar > 0 and not entry_in_window
    if not na(entry_line)
        line.delete(entry_line)
        entry_line := na
    if not na(sl_line)
        line.delete(sl_line)
        sl_line := na
    if not na(tp1_line)
        line.delete(tp1_line)
        tp1_line := na
    if not na(tp2_line)
        line.delete(tp2_line)
        tp2_line := na
    if not na(tp3_line)
        line.delete(tp3_line)
        tp3_line := na
    if not na(tp4_line)
        line.delete(tp4_line)
        tp4_line := na
    if not na(entry_lbl)
        label.delete(entry_lbl)
        entry_lbl := na
    if not na(sl_lbl)
        label.delete(sl_lbl)
        sl_lbl := na
    if not na(tp1_lbl)
        label.delete(tp1_lbl)
        tp1_lbl := na
    if not na(tp2_lbl)
        label.delete(tp2_lbl)
        tp2_lbl := na
    if not na(tp3_lbl)
        label.delete(tp3_lbl)
        tp3_lbl := na
    if not na(tp4_lbl)
        label.delete(tp4_lbl)
        tp4_lbl := na
// Draw entry/SL/TP once at signal bar; fixed segment (entry_bar → end_bar), no updating so lines don't "connect" to new bars
int start_bar = entry_bar
bool segment_visible = entry_in_window and start_bar < end_bar
if show_entry_sl_tp and entry_bar > 0 and not na(entry_level) and not na(sl_level) and segment_visible
    if na(entry_line)
        entry_line := line.new(start_bar, entry_level, end_bar, entry_level, color=color.blue, width=2)
        sl_line    := line.new(start_bar, sl_level, end_bar, sl_level, color=color.red, width=2)
        tp1_line   := not na(tp1_level) ? line.new(start_bar, tp1_level, end_bar, tp1_level, color=color.green, width=1) : na
        tp2_line   := not na(tp2_level) ? line.new(start_bar, tp2_level, end_bar, tp2_level, color=color.green, width=1) : na
        tp3_line   := not na(tp3_level) ? line.new(start_bar, tp3_level, end_bar, tp3_level, color=color.green, width=1) : na
        tp4_line   := not na(tp4_level) ? line.new(start_bar, tp4_level, end_bar, tp4_level, color=color.lime, width=2) : na
        entry_lbl  := label.new(end_bar, entry_level, " Entry ", style=label.style_label_left, color=color.blue, textcolor=color.white, size=size.small)
        sl_lbl     := label.new(end_bar, sl_level, " SL ", style=label.style_label_left, color=color.red, textcolor=color.white, size=size.small)
        tp1_lbl    := not na(tp1_level) ? label.new(end_bar, tp1_level, " TP1 ", style=label.style_label_left, color=color.green, textcolor=color.white, size=size.small) : na
        tp2_lbl    := not na(tp2_level) ? label.new(end_bar, tp2_level, " TP2 ", style=label.style_label_left, color=color.green, textcolor=color.white, size=size.small) : na
        tp3_lbl    := not na(tp3_level) ? label.new(end_bar, tp3_level, " TP3 ", style=label.style_label_left, color=color.green, textcolor=color.white, size=size.small) : na
        tp4_lbl    := not na(tp4_level) ? label.new(end_bar, tp4_level, " TP4 ", style=label.style_label_left, color=color.lime, textcolor=color.white, size=size.small) : na
// Entry/SL/TP and Liquidity shown only via line.new() segments (fixed bar length), not plot()
plot(show_eql_eqh ? eql_level : na, "EQL (inducement)", color.new(color.blue, 30), 1)
plot(show_eql_eqh ? eqh_level : na, "EQH (inducement)", color.new(color.red, 30), 1)

// Inversion labels (only when entry is taken, i.e. passed premium/discount filter)
if show_inv and sell_ok
    label.new(bar_index, high, "1H iFVG Sell", style=label.style_label_down, color=color.purple, textcolor=color.white, size=size.small)
if show_inv and buy_ok
    label.new(bar_index, low, "1H iFVG Buy", style=label.style_label_up, color=color.purple, textcolor=color.white, size=size.small)

// Alerts — inlined conditions; 4H trend filter: only Sell when bias==-1, only Buy when bias==1 (no counter-trend alerts).
alertcondition(bias == -1 and inv_bull_fvg and not na(entry_sell) and (not use_premium_discount or na(equilibrium) or entry_sell >= equilibrium), "Athena Inv V2.2 — 1H iFVG Sell", "{{ticker}} 1H iFVG SELL — retrace entry at mid of iFVG on {{interval}}")
alertcondition(bias == 1 and inv_bear_fvg and not na(entry_buy) and (not use_premium_discount or na(equilibrium) or entry_buy <= equilibrium), "Athena Inv V2.2 — 1H iFVG Buy", "{{ticker}} 1H iFVG BUY — retrace entry at mid of iFVG on {{interval}}")
alertcondition(sell_ok or buy_ok, "Athena Inv V2.2 — Any 1H iFVG Entry", "{{ticker}} 1H iFVG Entry on {{interval}}")
alertcondition(ob_limit_trigger_buy, "Athena Inv V2.2 — 4H POI + 1H ChoCH Limit Buy", "{{ticker}} Limit BUY at 1H OB (4H POI + 1H ChoCH) on {{interval}}")
alertcondition(ob_limit_trigger_sell, "Athena Inv V2.2 — 4H POI + 1H ChoCH Limit Sell", "{{ticker}} Limit SELL at 1H OB (4H POI + 1H ChoCH) on {{interval}}")
alertcondition(liq_poi_buy_trigger, "Athena Inv V2.2 — 1H POI + Liquidity (Buy)", "{{ticker}} Limit BUY at unmitigated 1H POI below EQL on {{interval}}")
alertcondition(liq_poi_sell_trigger, "Athena Inv V2.2 — 1H POI + Liquidity (Sell)", "{{ticker}} Limit SELL at unmitigated 1H POI above EQH on {{interval}}")
