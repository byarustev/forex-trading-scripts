//@version=5
indicator("Swing POI Entry Marker", "Swing POI Entries", overlay = true, max_labels_count = 500, max_lines_count = 500, max_boxes_count = 200)

// -------------------------------------------------------------------------------------------------
// Constants
// -------------------------------------------------------------------------------------------------
BULLISH_LEG = 1
BEARISH_LEG = 0
BULLISH = 1
BEARISH = -1

// -------------------------------------------------------------------------------------------------
// Inputs
// -------------------------------------------------------------------------------------------------
groupSwing = "Swing Bias (Lux-style)"
swingsLengthInput = input.int(50, "Swing Length", minval = 10, group = groupSwing)
showStrongWeakInput = input.bool(true, "Show Strong/Weak Labels", group = groupSwing)

groupPOI = "Strong POI Arming"
nearAtrMult = input.float(0.35, "Near POI Distance (ATR Mult)", minval = 0.05, step = 0.05, group = groupPOI)
atrLen = input.int(14, "ATR Length", minval = 1, group = groupPOI)

groupEntry = "Entry Logic"
contextTf = input.timeframe("240", "Context TF (HTF)", group = groupEntry)
use5mEntry = input.bool(true, "Use 5m Entry Criteria", group = groupEntry)
use15mEntry = input.bool(true, "Use 15m Entry Criteria", group = groupEntry)
useAutoEntryTfMap = input.bool(true, "Auto map entry TF by chart TF", group = groupEntry)
useImpulseObFvgPoi = input.bool(true, "Add Impulsive OB+FVG POIs", group = groupEntry)
useContinuationTrigger = input.bool(true, "Allow Continuation Trigger At POI", group = groupEntry)
continuationMaxTargetAtr = input.float(8.0, "Continuation: max distance to HTF target (ATR)", minval = 0.5, step = 0.5, group = groupEntry)
entryMinTargetAtr = input.float(0.3, "All entries: min distance to HTF target (ATR)", minval = 0.0, step = 0.25, group = groupEntry)
continuationMinTargetAtr = input.float(1.5, "Continuation: min distance to HTF target (ATR)", minval = 0.0, step = 0.25, group = groupEntry)
continuationNearPoiAtr = input.float(0.8, "Continuation: max distance from continuation POI mid (ATR)", minval = 0.1, step = 0.1, group = groupEntry)
safeLiquidityLookback = input.int(20, "Warning mode: liquidity lookback (bars)", minval = 5, maxval = 200, group = groupEntry)
safeEqhAtrTol = input.float(0.10, "Warning mode: equal-high ATR tolerance", minval = 0.01, step = 0.01, group = groupEntry)
useLegacyExternalPoiReversal = input.bool(true, "After confirmed flip: allow legacy external POI reactions", group = groupEntry)
useSweepFvgContinuation = input.bool(true, "Continuation: include liquidity sweep FVG taps", group = groupEntry)
continuationNowSignal = input.bool(true, "Continuation: trigger NOW signal immediately", group = groupEntry)
require5mObRetestAfterChoch = input.bool(true, "5m entries: require OB retest after CHOCH", group = groupEntry)
useExternalConfirmPoi = input.bool(true, "Add external-confirmation POIs (origin candle + impulse)", group = groupEntry)
externalPoiLookback = input.int(30, "External-confirmation origin lookback", minval = 5, maxval = 100, group = groupEntry)
useFirstBiasFlipPoi = input.bool(true, "Bias flip: add first origin POI (extreme candle + impulse)", group = groupEntry)
firstBiasPoiLookback = input.int(50, "Bias flip origin lookback", minval = 5, maxval = 150, group = groupEntry)
requireDirectionalDisplacementForPoi = input.bool(true, "POIs: require directional displacement", group = groupEntry)
usePremiumDiscountAutoEval = input.bool(true, "Auto-evaluate trades at Premium/Discount zones", group = groupEntry)
useCashVaultHtfPoi = input.bool(true, "Add Cash-Vault HTF POIs (OB+FVG)", group = groupEntry)
cashVaultProxAtrMult = input.float(1.2, "Cash-Vault POI proximity ATR", minval = 0.2, step = 0.1, group = groupEntry)
useCashVaultSwingObPoi = input.bool(true, "Cash-Vault: merge HTF swing OB", group = groupEntry)
cashVaultExtLen = input.int(4, "Cash-Vault external pivot length", minval = 2, group = groupEntry)
cashVaultSwingObLookback = input.int(50, "Cash-Vault swing OB lookback", minval = 10, maxval = 200, group = groupEntry)
cashVaultSwingObAtrLen = input.int(200, "Cash-Vault swing OB ATR len", minval = 14, maxval = 500, group = groupEntry)
useLargeDirectionalFvgPoi = input.bool(true, "Add large directional FVGs as POIs", group = groupEntry)
largeFvgMinAtr = input.float(0.8, "Large FVG min size (ATR)", minval = 0.1, step = 0.1, group = groupEntry)
useExpansionInefficiencyContext = input.bool(true, "Expansion leg: evaluate on discount/premium inefficiencies", group = groupEntry)
externalFlipAtrBuffer = input.float(0.05, "External bias flip buffer (ATR)", minval = 0.0, step = 0.01, group = groupEntry)
useAccumulationFilter = input.bool(true, "Filter accumulation markets", group = groupEntry)
minAdxForTrades = input.float(18.0, "Min ADX (entry TF)", minval = 0.0, maxval = 60.0, step = 1.0, group = groupEntry)
adxDiLen = input.int(14, "ADX DI length", minval = 2, maxval = 50, group = groupEntry)
adxSmooth = input.int(14, "ADX smoothing", minval = 1, maxval = 50, group = groupEntry)
internalLength = input.int(5, "Internal Pivot Length", minval = 2, group = groupEntry)
bodyImpulseMult = input.float(1.5, "Displacement Body Mult", minval = 1.0, step = 0.1, group = groupEntry)
bodyAvgLen = input.int(10, "Body Average Length", minval = 5, group = groupEntry)
originLookback = input.int(10, "Origin Candle Lookback", minval = 2, maxval = 50, group = groupEntry)
minRR = input.float(3.0, "Min RR", minval = 1.0, step = 0.25, group = groupEntry)

groupVisual = "Visuals"
showZones = input.bool(true, "Show Active Entry Zones", group = groupVisual)
showDebug = input.bool(false, "Show Debug Plots", group = groupVisual)
poiLineBars = input.int(8, "POI Short Line Length (bars)", minval = 2, maxval = 40, group = groupVisual)
limitLineBars = input.int(5, "Limit Price Line Length (bars)", minval = 2, maxval = 20, group = groupVisual)
nowLineBars = input.int(10, "NOW Entry Line Length (bars)", minval = 3, maxval = 50, group = groupVisual)

// -------------------------------------------------------------------------------------------------
// Data structures & State
// -------------------------------------------------------------------------------------------------
// ... (all your existing type definitions and var declarations remain unchanged until the new vars)

var pivot swingHigh = pivot.new(na, na, false, na, na)
var pivot swingLow = pivot.new(na, na, false, na, na)
var pivot internalHigh = pivot.new(na, na, false, na, na)
var pivot internalLow = pivot.new(na, na, false, na, na)

var trend swingTrend = trend.new(0)
var trend internalTrend = trend.new(0)
var int externalBias = 0
var int pendingExternalBias = 0
var int lastBiasFlipBar = na
var float protectedLow = na
var float protectedHigh = na
var int marketPhase = 0
var int pendingExternalFlipDir = 0

var trailingExtremes trailing = trailingExtremes.new(na, na, na, na, na, na)

// Pending zone state (unchanged)
var bool zoneActive = false
var int zoneDir = 0
var float zoneLow = na
var float zoneHigh = na
var int zoneBornBar = na
var bool zoneUsed = false
var int zoneTouchCount = 0
var bool zoneWasInside = false
var box activeZoneBox = na
var bool limitBullSignal = false
var bool limitBearSignal = false
var bool nowBullSignal = false
var bool nowBearSignal = false
var string nowSignalSuffix = ""
var float lastBullSignalPoiKey = na
var float lastBearSignalPoiKey = na

// ... (all your array declarations remain the same)

// NEW: Preserved Equilibrium for better POI arming
var float lastConfirmedEq    = na
var float preservedEq        = na
var int   lastConfirmedEqBar = na

// -------------------------------------------------------------------------------------------------
// Helper functions (unchanged - keep all your existing functions: leg(), startOfNewLeg(), updatePivot(), etc.)
// ... [All your helper functions from getCurrentStructure() to f_firstBiasFlipOriginPoi() stay exactly the same]

// -------------------------------------------------------------------------------------------------
// Core calculations
// -------------------------------------------------------------------------------------------------
atr = ta.atr(atrLen)
body = math.abs(close - open)
bodyAvg = ta.sma(body, bodyAvgLen)

// Keep trailing extremes live (unchanged)
if na(trailing.top)
    trailing.top := high
if na(trailing.bottom)
    trailing.bottom := low
trailing.top := math.max(trailing.top, high)
trailing.bottom := math.min(trailing.bottom, low)
trailing.lastTopTime := trailing.top == high ? time : trailing.lastTopTime
trailing.lastBottomTime := trailing.bottom == low ? time : trailing.lastBottomTime

// Build swing and internal structures (unchanged)
[newDemandPoi, outDemandTop, outDemandBot, outDemandBar, newSupplyPoi, outSupplyTop, outSupplyBot, outSupplyBar] = getCurrentStructure(swingsLengthInput, false)
[internalNewDemandPoi, internalOutDemandTop, internalOutDemandBot, internalOutDemandBar, internalNewSupplyPoi, internalOutSupplyTop, internalOutSupplyBot, internalOutSupplyBar] = getCurrentStructure(internalLength, true)

// ... [All security calls and LTF/HTF data fetching remain unchanged]

// NEW: Improved Equilibrium with preservation logic
rangeValid = not na(htfSwingHigh) and not na(htfSwingLow) and htfSwingHigh > htfSwingLow

if externalBias != nz(externalBias[1], 0) or na(lastConfirmedEq)
    // External bias just flipped → accept new range as confirmed
    lastConfirmedEq    := rangeValid ? math.avg(htfSwingHigh, htfSwingLow) : na
    lastConfirmedEqBar := bar_index
    preservedEq        := na
else if pendingExternalBias != 0
    // In CHOCH warning mode (pending flip) → preserve old confirmed eq for POI arming
    preservedEq := nz(lastConfirmedEq, math.avg(htfSwingHigh, htfSwingLow))
else
    // Normal case: update confirmed eq
    lastConfirmedEq    := rangeValid ? math.avg(htfSwingHigh, htfSwingLow) : lastConfirmedEq
    preservedEq        := na

eqForPd = not na(preservedEq) ? preservedEq : lastConfirmedEq
eq      = eqForPd   // This is now used for discount/premium and parent snapshots

inDiscount = rangeValid and close <= eq
inPremium  = rangeValid and close >= eq

// Use preserved/confirmed eq for new POI parent snapshots
parentEqSnapshot = not na(eqForPd) ? eqForPd : na

// ... [Rest of your code until the POI creation sections - when you push to arrays, use parentEqSnapshot as before]

// Strong levels, Cash-Vault, Continuation sweeps, etc. (unchanged except using new eq)

// In the zone evaluation loops, everything stays the same because inDiscount/inPremium now use preserved eq when needed.

// Debug plots (new)
plot(showDebug ? lastConfirmedEq : na, "Confirmed Eq (used for PD)", color=color.new(color.gray, 0), linewidth=2)
plot(showDebug ? preservedEq : na, "Preserved Eq (during warning)", color=color.new(color.orange, 0), linewidth=1)
plot(showDebug ? eq : na, "Final Eq (for PD)", color=color.new(color.blue, 50))

// ... [All the rest of your script from "nearStrongLow" evaluation down to the end remains 100% unchanged]

alertcondition(nowBullSignal, "Bullish Entry", "BUY NOW signal")
alertcondition(nowBearSignal, "Bearish Entry", "SELL NOW signal")
alertcondition(limitBullSignal, "Bullish Limit Setup", "BUY LIMIT setup created")
alertcondition(limitBearSignal, "Bearish Limit Setup", "SELL LIMIT setup created")
plot(showDebug ? marketPhase : na, "Market Phase", color = color.new(color.blue, 0))
plot(showDebug ? entryAdx : na, "Entry ADX", color = color.new(color.orange, 0))